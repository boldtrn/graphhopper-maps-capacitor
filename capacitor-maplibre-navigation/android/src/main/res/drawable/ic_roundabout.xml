    <!-- 3/4 circle arc (counterclockwise from bottom to right, gap at bottom-right) -->
    <path
        android:pathData="M12,16 A4,4 0,1,0 16,12"
        android:strokeWidth="2"
        android:strokeColor="#000000"
        android:strokeLineCap="round" />
    <!-- Exit line from circle going right -->
    <path
        android:pathData="M16,12 L20,12"
        android:strokeWidth="2"
        android:strokeColor="#000000"
        android:strokeLineCap="round" />
    <!-- Arrowhead at exit -->
    <path
        android:pathData="M18,10 L20,12 L18,14"
        android:strokeWidth="2"
        android:strokeColor="#000000"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
    <!-- Entry line from bottom into circle -->
    <path
        android:pathData="M12,21 V16"
        android:strokeWidth="2"
        android:strokeColor="#000000"
        android:strokeLineCap="round" />
</vector>
