<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Map View (full screen) -->
    <org.maplibre.android.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top Bar: Turn instruction (margins set by setupWindowInsets) -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="@drawable/bg_card"
        android:elevation="4dp">

        <!-- Turn Icon -->
        <ImageView
            android:id="@+id/turnIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_straight"
            android:contentDescription="Turn direction" />

        <!-- Instruction area -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:orientation="vertical">

            <!-- Distance to next turn -->
            <TextView
                android:id="@+id/distanceToTurnText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="24sp"
                android:textColor="#000000"
                android:textStyle="bold"
                tools:text="250 m" />

            <!-- Instruction Text -->
            <TextView
                android:id="@+id/instructionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#444444"
                android:maxLines="2"
                android:ellipsize="end"
                tools:text="Turn right onto Main Street" />

        </LinearLayout>

        <!-- Mute Button -->
        <ImageButton
            android:id="@+id/muteButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_volume_up"
            android:contentDescription="Toggle voice instructions" />

    </LinearLayout>

    <!-- Re-center button (shown when user pans the map) -->
    <ImageButton
        android:id="@+id/recenterButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="200dp"
        android:src="@drawable/ic_my_location"
        android:background="@drawable/bg_card"
        android:elevation="4dp"
        android:visibility="gone"
        android:contentDescription="Re-center map" />

    <!-- Bottom container: speed panel + info bar -->
    <LinearLayout
        android:id="@+id/bottomContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:elevation="4dp">

        <!-- Speed panel (small, left-aligned, above info bar) -->
        <LinearLayout
            android:id="@+id/speedPanel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical|end"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:background="@drawable/bg_card">

            <TextView
                android:id="@+id/currentSpeedText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="28sp"
                android:textColor="#000000"
                android:textStyle="bold"
                tools:text="45" />

            <TextView
                android:id="@+id/speedUnitText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textSize="14sp"
                android:textColor="#666666"
                android:text="km/h" />

        </LinearLayout>

        <!-- Bottom Bar: ETA, time, distance + stop button -->
        <LinearLayout
            android:id="@+id/bottomBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:background="@drawable/bg_bottom_bar">

            <!-- ETA -->
            <TextView
                android:id="@+id/etaText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textSize="22sp"
                android:textColor="#000000"
                android:textStyle="bold"
                tools:text="14:35" />

            <!-- Remaining Time -->
            <TextView
                android:id="@+id/remainingTimeText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textSize="22sp"
                android:textColor="#000000"
                android:textStyle="bold"
                tools:text="12 min" />

            <!-- Remaining Distance -->
            <TextView
                android:id="@+id/remainingDistanceText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textSize="22sp"
                android:textColor="#000000"
                android:textStyle="bold"
                tools:text="5.2 km" />

            <!-- Stop Button -->
            <ImageButton
                android:id="@+id/stopButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_close"
                android:background="@drawable/bg_stop_button"
                android:contentDescription="Stop navigation" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
